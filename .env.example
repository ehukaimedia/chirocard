# ChiroCard environment variables
# Copy this file to .env and fill in values as needed.

# --- App build-time vars (Vite) ---
# Optional. The Google Tag Manager container for OPT-IN analytics. If unset,
# analytics is simply off. Loaded lazily and only after the user consents
# (see src/lib/consent.ts). Must be VITE_-prefixed to reach the client bundle.
VITE_GTM_ID=

# --- Tooling vars (Google Webmaster MCP CLI: google-webmaster-audit, etc.) ---
# These are NOT used by the app build; only by the analytics/SEO CLI tooling.

# Google Tag Manager
GTM_ID=
# GTM_WORKSPACE_ID=  # only needed if your container has multiple workspaces

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_MID=

# Google Search Console — use sc-domain: prefix for domain properties
GSC_SITE=
