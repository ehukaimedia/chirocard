# ChiroCard environment variables
# Copy this file to .env and fill in values as needed.
# The app works fully offline without any of these — they are all optional integrations.

# Google Maps (unused since switching to Photon/OpenStreetMap for place search)
# VITE_GOOGLE_MAPS_API_KEY=

# Google Analytics / Tag Manager (optional analytics)
# GTM_ID=
# GA4_PROPERTY_ID=
# GA4_MID=

# Google Search Console verification (optional)
# GSC_SITE=
