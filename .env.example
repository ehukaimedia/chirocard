# ChiroCard environment variables
# Copy this file to .env and fill in values as needed.
# Used by Google Webmaster MCP CLI (google-webmaster-audit, etc.)
# See: /Volumes/Extreme SSD/AI-Applications/Google-Webmaster-MCP/README.md

# Google Tag Manager
GTM_ID=
# GTM_WORKSPACE_ID=  # only needed if your container has multiple workspaces

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_MID=

# Google Search Console
GSC_SITE=
